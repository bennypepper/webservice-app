<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/colorBackground">

    <!-- App Bar with back arrow -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/colorForest"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="18dp"
        android:paddingBottom="18dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Back arrow -->
            <TextView
                android:id="@+id/btnBack"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="‹"
                android:textSize="28sp"
                android:textColor="@color/colorWhite"
                android:layout_marginEnd="12dp"
                android:paddingBottom="2dp"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tambah Mahasiswa"
                    android:textColor="@color/colorWhite"
                    android:textSize="19sp"
                    android:textStyle="bold"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ISI DATA BARU"
                    android:textColor="@color/colorGoldSoft"
                    android:textSize="10sp"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.05"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- Form Body -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="22dp">

            <!-- NIM -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="NIM"
                android:textColor="@color/colorMuted"
                android:textSize="10.5sp"
                android:fontFamily="monospace"
                android:letterSpacing="0.06"
                android:layout_marginBottom="7dp"/>
            <EditText
                android:id="@+id/etNIM"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_field"
                android:inputType="text"
                android:maxLength="15"
                android:hint="Contoh: 312210001"
                android:textColorHint="@color/colorSageLine"
                android:textColor="@color/colorInk"
                android:textSize="14sp"
                android:paddingHorizontal="14dp"
                android:layout_marginBottom="18dp"/>

            <!-- Nama -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="NAMA"
                android:textColor="@color/colorMuted"
                android:textSize="10.5sp"
                android:fontFamily="monospace"
                android:letterSpacing="0.06"
                android:layout_marginBottom="7dp"/>
            <EditText
                android:id="@+id/etNama"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_field"
                android:inputType="textPersonName"
                android:hint="Nama lengkap mahasiswa"
                android:textColorHint="@color/colorSageLine"
                android:textColor="@color/colorInk"
                android:textSize="14sp"
                android:paddingHorizontal="14dp"
                android:layout_marginBottom="18dp"/>

            <!-- Jurusan -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="JURUSAN"
                android:textColor="@color/colorMuted"
                android:textSize="10.5sp"
                android:fontFamily="monospace"
                android:letterSpacing="0.06"
                android:layout_marginBottom="7dp"/>
            <EditText
                android:id="@+id/etJurusan"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_field"
                android:inputType="text"
                android:hint="Contoh: Teknik Informatika"
                android:textColorHint="@color/colorSageLine"
                android:textColor="@color/colorInk"
                android:textSize="14sp"
                android:paddingHorizontal="14dp"
                android:layout_marginBottom="18dp"/>

            <!-- Alamat -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ALAMAT"
                android:textColor="@color/colorMuted"
                android:textSize="10.5sp"
                android:fontFamily="monospace"
                android:letterSpacing="0.06"
                android:layout_marginBottom="7dp"/>
            <EditText
                android:id="@+id/etAlamat"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="80dp"
                android:background="@drawable/bg_field"
                android:inputType="textMultiLine"
                android:gravity="top|start"
                android:hint="Alamat tempat tinggal saat ini"
                android:textColorHint="@color/colorSageLine"
                android:textColor="@color/colorInk"
                android:textSize="13sp"
                android:paddingHorizontal="14dp"
                android:paddingVertical="12dp"
                android:layout_marginBottom="30dp"/>

            <!-- Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="fill_horizontal">

                <Button
                    android:id="@+id/btnBatal"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_weight="1"
                    android:text="Batal"
                    android:background="@drawable/btn_ghost"
                    android:textColor="@color/colorMuted"
                    android:textSize="13.5sp"
                    android:textStyle="bold"
                    android:stateListAnimator="@null"
                    android:layout_marginEnd="10dp"/>

                <Button
                    android:id="@+id/btnSimpan"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_weight="1"
                    android:text="Simpan"
                    android:background="@drawable/btn_primary"
                    android:textColor="@color/colorWhite"
                    android:textSize="13.5sp"
                    android:textStyle="bold"
                    android:stateListAnimator="@null"/>
            </LinearLayout>

            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:indeterminateTint="@color/colorForest"
                android:layout_marginTop="14dp"
                android:visibility="gone"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
