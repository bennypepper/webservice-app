<?xml version="1.0" encoding="utf-8"?>
<!-- Index-card style student item card -->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="5dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/colorWhite"
    app:strokeColor="@color/colorSageLine"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="14dp"
        android:gravity="center_vertical">

        <!-- Avatar initials tag -->
        <TextView
            android:id="@+id/tvAvatar"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_avatar"
            android:gravity="center"
            android:textColor="@color/colorForest"
            android:textSize="15sp"
            android:textStyle="bold"
            android:layout_marginEnd="12dp"
            android:text="RA"/>

        <!-- Student info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvNama"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="14.5sp"
                android:textStyle="bold"
                android:textColor="@color/colorInk"
                android:maxLines="1"
                android:ellipsize="end"
                android:text="Nama Mahasiswa"/>

            <TextView
                android:id="@+id/tvJurusan"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="@color/colorMuted"
                android:layout_marginTop="2dp"
                android:maxLines="1"
                android:ellipsize="end"
                android:text="Teknik Informatika"/>

            <!-- NIM badge -->
            <TextView
                android:id="@+id/tvNIM"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_nim_badge"
                android:textColor="@color/colorForest"
                android:textSize="10.5sp"
                android:fontFamily="monospace"
                android:paddingStart="7dp"
                android:paddingEnd="7dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:layout_marginTop="6dp"
                android:text="312210001"/>
        </LinearLayout>

        <!-- Chevron -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="›"
            android:textSize="22sp"
            android:textColor="@color/colorSageLine"
            android:layout_marginStart="8dp"/>

    </LinearLayout>
</androidx.cardview.widget.CardView>
