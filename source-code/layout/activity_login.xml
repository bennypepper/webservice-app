<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/colorForestDark">

    <!-- Brand header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingHorizontal="36dp">

        <!-- Eyebrow line -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="WEB SERVICE · UAS"
                android:textColor="@color/colorGold"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:letterSpacing="0.12"/>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sistem Data\nMahasiswa"
            android:textColor="@color/colorWhite"
            android:textSize="30sp"
            android:textStyle="bold"
            android:lineSpacingMultiplier="1.1"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ma Chung University"
            android:textColor="@color/colorGoldSoft"
            android:textSize="13sp"
            android:layout_marginBottom="52dp"/>

        <!-- Username -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="USERNAME"
            android:textColor="@color/colorGoldSoft"
            android:textSize="10sp"
            android:fontFamily="monospace"
            android:letterSpacing="0.1"
            android:layout_marginBottom="6dp"/>
        <EditText
            android:id="@+id/etUsername"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/bg_field_filled"
            android:inputType="text"
            android:padding="14dp"
            android:textColor="@color/colorInk"
            android:textColorHint="#99888888"
            android:hint="Username"
            android:layout_marginBottom="16dp"/>

        <!-- Password -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="PASSWORD"
            android:textColor="@color/colorGoldSoft"
            android:textSize="10sp"
            android:fontFamily="monospace"
            android:letterSpacing="0.1"
            android:layout_marginBottom="6dp"/>
        <EditText
            android:id="@+id/etPassword"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/bg_field_filled"
            android:inputType="textPassword"
            android:padding="14dp"
            android:textColor="@color/colorInk"
            android:textColorHint="#99888888"
            android:hint="Password"
            android:layout_marginBottom="28dp"/>

        <!-- Login Button -->
        <Button
            android:id="@+id/btnLogin"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="MASUK"
            android:backgroundTint="@color/colorGold"
            android:textColor="@color/colorForestDark"
            android:textSize="14sp"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            android:stateListAnimator="@null"/>

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:indeterminateTint="@color/colorGold"
            android:layout_marginTop="16dp"
            android:visibility="gone"/>
    </LinearLayout>

    <!-- Footer -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="© 2026 Teknik Informatika — Ma Chung University"
        android:textColor="#44FFFFFF"
        android:textSize="10sp"
        android:fontFamily="monospace"
        android:gravity="center"
        android:paddingBottom="24dp"/>

</LinearLayout>
